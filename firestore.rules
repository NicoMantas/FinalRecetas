rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'users'
    // Permite a un usuario leer y escribir sus propios datos.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null; // Cualquiera autenticado puede crear un perfil de usuario (registrarse)
    }

    // Reglas para la colección 'recipes'
    // Permite a cualquiera leer recetas.
    // Permite a usuarios autenticados crear, actualizar y eliminar recetas.
    match /recipes/{recipeId} {
      allow get, list: if true; // Cualquiera puede leer
      allow create, update, delete: if request.auth != null; // Solo autenticados pueden escribir
    }

    // Reglas para la colección 'favorites' (subcolección de users)
    // Permite a un usuario gestionar sus propios favoritos.
    match /users/{userId}/favorites/{favoriteId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // NUEVAS REGLAS PARA EL INVENTARIO
    // Permite a usuarios autenticados leer, crear, actualizar y eliminar items del inventario.
    // Considera refinar estas reglas si necesitas un control de acceso más granular (ej. roles de administrador).
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Es importante que no haya una regla más general como match /{document=**} { allow read, write: if false; }
    // al final, ya que podría sobreescribir estas reglas específicas. Si necesitas una regla "catch-all",
    // asegúrate de que sea menos permisiva que las específicas o colócala antes de las más específicas si la lógica lo requiere.
    // O simplemente omítela si todas tus colecciones tendrán reglas explícitas.
  }
}